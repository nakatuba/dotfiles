{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "external_directory": {
      "~/ghq/*": "allow"
    }
  },
  "mcp": {
    "notion": {
      "type": "remote",
      "url": "https://mcp.notion.com/mcp",
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": true
    }
  },
  "plugin": ["opencode-anthropic-auth@latest"]
}
