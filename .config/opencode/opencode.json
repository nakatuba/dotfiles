{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "external_directory": {
      "~/ghq/*": "allow"
    }
  },
  "mcp": {
    "dbhub": {
      "type": "local",
      "command": [
        "npx",
        "@bytebase/dbhub@latest",
        "--transport",
        "stdio",
        "--dsn",
        "{env:DATABASE_URL}"
      ],
      "enabled": true
    },
    "notion": {
      "type": "remote",
      "url": "https://mcp.notion.com/mcp",
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": true
    }
  },
  "plugin": ["opencode-claude-auth@latest"]
}
