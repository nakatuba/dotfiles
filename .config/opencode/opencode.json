{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "git push *": "deny"
    },
    "external_directory": {
      "~/dotfiles/**": "allow",
      "~/ghq/**": "allow",
      "~/worktrees/**": "allow"
    }
  },
  "mcp": {
    "dbhub": {
      "type": "local",
      "command": [
        "npx",
        "-p",
        "pg",
        "-p",
        "@bytebase/dbhub@latest",
        "dbhub",
        "--transport",
        "stdio",
        "--dsn",
        "{env:DATABASE_URL}"
      ],
      "enabled": false
    },
    "notion": {
      "type": "remote",
      "url": "https://mcp.notion.com/mcp",
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": true
    },
    "serena": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context=ide",
        "--project-from-cwd",
        "--enable-web-dashboard=false"
      ],
      "enabled": true
    }
  },
  "plugin": ["opencode-anthropic-oauth"]
}
