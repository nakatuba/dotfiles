[user]
  name = nakatuba
  email = nakatuba0626@gmail.com

[init]
  defaultBranch = main

[fetch]
  prune = true

[pull]
  ff = only

[push]
  autoSetupRemote = true

[alias]
  co = checkout
  br = branch
  ci = commit
  st = status

[core]
  quotepath = false

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
